{
  "manifest_version": 3,
  "name": "Subtitle Masker Extension",
  "description": "Mask hardcoded subtitles on videos with adjustable overlays.",
  "version": "0.2.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Subtitle Masker"
  },
  "commands": {
    "toggle-mask": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Toggle subtitle mask on current page"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
